{
  "name": "hls-ts",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "import": "./dist/hls.mjs",
      "require": "./dist/hls.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "bun build ./index.ts --outdir=./dist --target=browser --format=esm --minify && bun run build:types",
    "build:types": "tsc -p tsconfig-lib.json",
    "dev": "bun --watch run index.ts",
    "demo": "bun run demo2/server.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
